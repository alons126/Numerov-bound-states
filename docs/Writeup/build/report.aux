\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces First four bound states of the quartic double-well potential. The lowest two states form a nearly degenerate tunneling doublet.}}{11}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dw_states}{{15}{11}{First four bound states of the quartic double-well potential. The lowest two states form a nearly degenerate tunneling doublet}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Probability densities $|\psi (x)|^2$ for the first four double-well states. The lowest even and odd states have nearly identical densities, as expected for a tunneling doublet.}}{11}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dw_densities}{{16}{11}{Probability densities $|\psi (x)|^2$ for the first four double-well states. The lowest even and odd states have nearly identical densities, as expected for a tunneling doublet}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Raw shooting mismatch functions for even (top) and odd (bottom) double-well states. The zero crossings define the numerical eigenvalues.}}{11}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dw_shooting}{{17}{11}{Raw shooting mismatch functions for even (top) and odd (bottom) double-well states. The zero crossings define the numerical eigenvalues}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Zoomed root brackets for the lowest even (a) and odd (b) double-well states. These local panels show the raw mismatch and the recorded bisection sequence inside the initial sign-changing brackets.}}{11}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dw_shooting_zoom}{{18}{11}{Zoomed root brackets for the lowest even (a) and odd (b) double-well states. These local panels show the raw mismatch and the recorded bisection sequence inside the initial sign-changing brackets}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Grid convergence for the quartic double well. The energy errors decrease with high-order behavior under successive grid refinement.}}{12}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dw_convergence_h}{{19}{12}{Grid convergence for the quartic double well. The energy errors decrease with high-order behavior under successive grid refinement}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Dependence of the double-well energy errors on box size. The errors decrease rapidly as the domain is enlarged and then reach a numerical plateau.}}{12}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dw_convergence_xmax}{{20}{12}{Dependence of the double-well energy errors on box size. The errors decrease rapidly as the domain is enlarged and then reach a numerical plateau}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces Energy splitting between the two lowest double-well states as the parameter $b$ is varied. The splitting decreases as the barrier becomes stronger, consistent with tunneling suppression.}}{12}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dw_splitting}{{21}{12}{Energy splitting between the two lowest double-well states as the parameter $b$ is varied. The splitting decreases as the barrier becomes stronger, consistent with tunneling suppression}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces First four finite square well states plotted together with the finite barrier potential. States below the barrier are localized in the well, while the near-threshold state has a larger evanescent tail.}}{13}{figure.caption.8}\protected@file@percent }
\newlabel{fig:finitewell_states}{{22}{13}{First four finite square well states plotted together with the finite barrier potential. States below the barrier are localized in the well, while the near-threshold state has a larger evanescent tail}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces Probability densities $|\psi (x)|^2$ for the first four finite square well states. The densities show both interior oscillation and exterior exponential leakage.}}{13}{figure.caption.8}\protected@file@percent }
\newlabel{fig:finitewell_densities}{{23}{13}{Probability densities $|\psi (x)|^2$ for the first four finite square well states. The densities show both interior oscillation and exterior exponential leakage}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces Raw shooting mismatch functions for even (a) and odd (b) finite-well states. The global scans include the near-threshold regime just below the barrier top $V_0$.}}{13}{figure.caption.8}\protected@file@percent }
\newlabel{fig:finitewell_shooting}{{24}{13}{Raw shooting mismatch functions for even (a) and odd (b) finite-well states. The global scans include the near-threshold regime just below the barrier top $V_0$}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces Zoomed near-threshold brackets for the higher even (a) and odd (b) finite-well bound states. These views isolate the genuine sign-changing roots close to the barrier top and show the full recorded bisection history.}}{13}{figure.caption.8}\protected@file@percent }
\newlabel{fig:finitewell_shooting_zoom}{{25}{13}{Zoomed near-threshold brackets for the higher even (a) and odd (b) finite-well bound states. These views isolate the genuine sign-changing roots close to the barrier top and show the full recorded bisection history}{figure.caption.8}{}}
