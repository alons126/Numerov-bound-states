\def\@LN@column{1}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Finite square well}{9}{subsection.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces First four finite square well states plotted together with the finite barrier potential. States below the barrier are localized in the well, while the near-threshold state has a larger evanescent tail.}}{9}{figure.19}\protected@file@percent }
\newlabel{fig:finitewell_states}{{19}{9}{First four finite square well states plotted together with the finite barrier potential. States below the barrier are localized in the well, while the near-threshold state has a larger evanescent tail}{figure.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Probability densities $|\psi (x)|^2$ for the first four finite square well states. The densities show both interior oscillation and exterior exponential leakage.}}{9}{figure.20}\protected@file@percent }
\newlabel{fig:finitewell_densities}{{20}{9}{Probability densities $|\psi (x)|^2$ for the first four finite square well states. The densities show both interior oscillation and exterior exponential leakage}{figure.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces First four bound states of the quartic double-well potential. The lowest two states form a nearly degenerate tunneling doublet.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dw_states}{{13}{10}{First four bound states of the quartic double-well potential. The lowest two states form a nearly degenerate tunneling doublet}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Probability densities $|\psi (x)|^2$ for the first four double-well states. The lowest even and odd states have nearly identical densities, as expected for a tunneling doublet.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dw_densities}{{14}{10}{Probability densities $|\psi (x)|^2$ for the first four double-well states. The lowest even and odd states have nearly identical densities, as expected for a tunneling doublet}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Shooting mismatch functions for even (top) and odd (bottom) double-well states. The zero crossings define the numerical eigenvalues.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:dw_shooting}{{15}{10}{Shooting mismatch functions for even (top) and odd (bottom) double-well states. The zero crossings define the numerical eigenvalues}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Grid convergence for the quartic double well. The energy errors decrease with high-order behavior under successive grid refinement.}}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dw_convergence_h}{{16}{11}{Grid convergence for the quartic double well. The energy errors decrease with high-order behavior under successive grid refinement}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Dependence of the double-well energy errors on box size. The errors decrease rapidly as the domain is enlarged and then reach a numerical plateau.}}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dw_convergence_xmax}{{17}{11}{Dependence of the double-well energy errors on box size. The errors decrease rapidly as the domain is enlarged and then reach a numerical plateau}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Energy splitting between the two lowest double-well states as the parameter $b$ is varied. The splitting decreases as the barrier becomes stronger, consistent with tunneling suppression.}}{11}{figure.caption.7}\protected@file@percent }
\newlabel{fig:dw_splitting}{{18}{11}{Energy splitting between the two lowest double-well states as the parameter $b$ is varied. The splitting decreases as the barrier becomes stronger, consistent with tunneling suppression}{figure.caption.7}{}}
