{
  "python.analysis.extraPaths": ["."],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.outDir": "%DIR%/build",
  "latex-workshop.latex.recipes": [
    {
      "name": "active-document",
      "tools": ["active-latexmk"]
    },
    {
      "name": "Writeup",
      "tools": ["writeup-latexmk"]
    },
    {
      "name": "proposal",
      "tools": ["proposal-latexmk"]
    },
    {
      "name": "project-outline-and-motivation",
      "tools": ["project-outline-latexmk"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "active-latexmk",
      "command": "sh",
      "args": [
        "-c",
        "latexmk -e '$max_repeat=8' -cd -outdir=build -pdf -interaction=nonstopmode -synctex=1 -f \"$1\"; status=$?; if [ -f \"docs/Writeup/build/Writeup.pdf\" ]; then cp \"docs/Writeup/build/Writeup.pdf\" \"Writeup - final assignment - Alon Sportes.pdf\"; fi; exit $status",
        "latexmk-active",
        "%DOC%"
      ]
    },
    {
      "name": "writeup-latexmk",
      "command": "sh",
      "args": [
        "-c",
        "latexmk -e '$max_repeat=8' -cd -outdir=build -pdf -interaction=nonstopmode -synctex=1 -f docs/Writeup/Writeup.tex; status=$?; if [ -f \"docs/Writeup/build/Writeup.pdf\" ]; then cp \"docs/Writeup/build/Writeup.pdf\" \"Writeup - final assignment - Alon Sportes.pdf\"; fi; exit $status"
      ]
    },
    {
      "name": "proposal-latexmk",
      "command": "latexmk",
      "args": [
        "-e",
        "$max_repeat=8",
        "-cd",
        "-outdir=build",
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-f",
        "docs/Proposal/proposal.tex"
      ]
    },
    {
      "name": "project-outline-latexmk",
      "command": "latexmk",
      "args": [
        "-e",
        "$max_repeat=8",
        "-cd",
        "-outdir=build",
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-f",
        "docs/Project_outline_and_motivation/Project_outline_and_motivation.tex"
      ]
    }
  ],
  "emeraldwalk.runonsave": {
    "commands": []
  }
}
