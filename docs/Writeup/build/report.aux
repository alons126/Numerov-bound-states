\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Raw boundary mismatch functions for even (a) and odd (b) states. The zero crossings correspond to the physical eigenvalues found by the shooting method.}}{5}{figure.caption.3}\protected@file@percent }
\newlabel{fig:infwell_shooting}{{3}{5}{Raw boundary mismatch functions for even (a) and odd (b) states. The zero crossings correspond to the physical eigenvalues found by the shooting method}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Zoomed root brackets for the lowest even (a) and odd (b) infinite-well states. These panels show the raw mismatch only inside one initial sign-changing bracket, together with the recorded bisection iterates.}}{5}{figure.caption.3}\protected@file@percent }
