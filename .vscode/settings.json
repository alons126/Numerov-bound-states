{
  "python.analysis.extraPaths": ["."],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.outDir": "%DIR%/build",
  "latex-workshop.latex.recipes": [
    {
      "name": "active-document",
      "tools": ["active-latexmk"]
    },
    {
      "name": "Writeup",
      "tools": ["writeup-latexmk", "copy-writeup-pdf", "copy-writeup-pdf-to-writeup"]
    },
    {
      "name": "proposal",
      "tools": ["proposal-latexmk"]
    },
    {
      "name": "project-outline-and-motivation",
      "tools": ["project-outline-latexmk"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "active-latexmk",
      "command": "sh",
      "args": [
        "-c",
        "latexmk -cd -outdir=build -pdf -interaction=nonstopmode -synctex=1 -f \"$1\" && if [ \"$2\" = \"Writeup.tex\" ]; then cp \"$3/build/Writeup.pdf\" \"$3/../Writeup.pdf\"; fi",
        "latexmk-active",
        "%DOC%",
        "%DOCFILE%",
        "%DIR%"
      ]
    },
    {
      "name": "writeup-latexmk",
      "command": "latexmk",
      "args": [
        "-cd",
        "-outdir=build",
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-f",
        "docs/Writeup/Writeup.tex"
      ]
    },
    {
      "name": "copy-writeup-pdf",
      "command": "cp",
      "args": ["docs/Writeup/build/Writeup.pdf", "docs/Writeup.pdf"]
    },
    {
      "name": "copy-writeup-pdf-to-writeup",
      "command": "cp",
      "args": ["docs/Writeup/build/Writeup.pdf", "docs/Writeup/Writeup.pdf"]
    },
    {
      "name": "proposal-latexmk",
      "command": "latexmk",
      "args": [
        "-cd",
        "-outdir=build",
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-f",
        "docs/Proposal/proposal.tex"
      ]
    },
    {
      "name": "project-outline-latexmk",
      "command": "latexmk",
      "args": [
        "-cd",
        "-outdir=build",
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-f",
        "docs/Project_outline_and_motivation/Project_outline_and_motivation.tex"
      ]
    }
  ],
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": ".*",
        "isAsync": true,
        "cmd": "cd \"${workspaceFolder}\" && latexmk -cd -outdir=build -pdf -interaction=nonstopmode -synctex=1 -f \"docs/Writeup/Writeup.tex\" && cp \"docs/Writeup/build/Writeup.pdf\" \"${workspaceFolder}/docs/Writeup.pdf\" && latexmk -cd -outdir=build -pdf -interaction=nonstopmode -synctex=1 -f \"docs/Proposal/proposal.tex\" && latexmk -cd -outdir=build -pdf -interaction=nonstopmode -synctex=1 -f \"docs/Project_outline_and_motivation/Project_outline_and_motivation.tex\""
      }
    ]
  }
}
